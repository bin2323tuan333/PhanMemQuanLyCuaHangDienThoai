                                        style="-fx-background-color: white; -fx-border-color: #ced4da; -fx-background-radius: 6px; -fx-border-radius: 6px; -fx-text-fill: #495057;">
                                    <font>
                                        <Font size="14.0"/>
                                    </font>
                                    <cursor>
                                        <Cursor fx:constant="HAND"/>
                                    </cursor>
                                    <graphic>
                                        <ImageView fx:id="btn_add_customer" fitHeight="24.0" fitWidth="24.0"
                                                   pickOnBounds="true" preserveRatio="true">
                                            <image>
                                                <Image url="@../../../image/plus.png"/>
                                            </image>
                                        </ImageView>
                                    </graphic>
                                    <padding>
                                        <Insets bottom="6.0" left="6.0" right="6.0" top="6.0"/>
                                    </padding>
                                </Button>
                            </children>
                            <padding>
                                <Insets bottom="5.0" left="10.0" right="10.0" top="5.0"/>
                            </padding>
                        </HBox>
                        <GridPane hgap="15.0"
