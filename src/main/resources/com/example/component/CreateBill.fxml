            <children>
                <VBox prefHeight="167.0" prefWidth="1600.0" spacing="20.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Label text="Thông tin khách hàng">
                            <font>
                                <Font name="System Bold" size="16.0"/>
                            </font>
                        </Label>
                        <HBox prefHeight="23.0" prefWidth="218.0" spacing="20.0">
                            <children>
                                <TextField fx:id="txt_search_customer" prefHeight="38.0" prefWidth="17.0"
