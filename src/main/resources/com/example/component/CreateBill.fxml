                                <Label prefHeight="25.0" prefWidth="71.0" text="Tổng tiền" textFill="#555555">
                                    <font>
                                        <Font size="16.0"/>
                                    </font>
                                </Label>
                                <Region prefHeight="25.0" prefWidth="34.0" HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lb_total_price" text="0" textFill="#333333">
                                    <font>
                                        <Font name="System Bold" size="18.0"/>
                                    </font>
                                </Label>
                            </children>
                            <padding>
                                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                            </padding>
                        </HBox>
                        <HBox prefHeight="21.0" prefWidth="351.0" spacing="10.0">
                            <children>
                                <Button mnemonicParsing="false"
                                        style="-fx-background-color: transparent; -fx-border-color: #ced4da; -fx-border-radius: 6px; -fx-background-radius: 6px;"
                                        text="Xóa tất cả" textFill="#495057" HBox.hgrow="ALWAYS"
                                        onAction="#handleBtnDeleteCart">
                                    <graphic>
                                        <ImageView fitHeight="32.0" fitWidth="32.0" pickOnBounds="true"
                                                   preserveRatio="true">
                                            <image>
                                                <Image url="@../../../image/trash-2.png"/>
                                            </image>
                                        </ImageView>
                                    </graphic>
                                    <padding>
                                        <Insets bottom="10.0" left="20.0" right="20.0" top="10.0"/>
                                    </padding>
                                    <cursor>
                                        <Cursor fx:constant="HAND"/>
                                    </cursor>
                                    <font>
                                        <Font size="14.0"/>
                                    </font>
                                </Button>
                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="40.0"
                                        prefWidth="149.0"
                                        style="-fx-background-color: #e9ecef; -fx-border-color: #ced4da; -fx-border-radius: 6px; -fx-background-radius: 6px;"
                                        text="Thanh toán" textFill="#495057" HBox.hgrow="ALWAYS"
                                        onAction="#handleBtnCheckout">
                                    <graphic>
                                        <ImageView fitHeight="32.0" fitWidth="32.0" pickOnBounds="true"
                                                   preserveRatio="true">
                                            <image>
                                                <Image url="@../../../image/credit-card.png"/>
                                            </image>
                                        </ImageView>
                                    </graphic>
                                    <padding>
                                        <Insets bottom="10.0" left="20.0" right="20.0" top="10.0"/>
                                    </padding>
                                    <cursor>
                                        <Cursor fx:constant="HAND"/>
                                    </cursor>
                                    <font>
                                        <Font size="14.0"/>
                                    </font>
                                </Button>
                            </children>
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                            </padding>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</HBox>
