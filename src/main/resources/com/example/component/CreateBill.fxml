<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox fx:id="main_container" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity"
      minWidth="-Infinity" prefHeight="900.0" prefWidth="817.0" VBox.vgrow="ALWAYS" xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.controllers.ComponentControllers.CreateBillController">
    <children>

        <VBox fx:id="product_container" maxHeight="1.7976931348623157E308" prefHeight="263.0" prefWidth="558.0"
              HBox.hgrow="ALWAYS">
            <children>
                <Label maxWidth="1.7976931348623157E308" text="Chọn sản phẩm" textFill="#333333">
                    <font>
                        <Font name="System Bold" size="18.0"/>
                    </font>
                    <padding>
                        <Insets bottom="15.0" top="10.0"/>
                    </padding>
                </Label>
                <HBox maxWidth="1.7976931348623157E308" prefHeight="26.0" prefWidth="314.0" spacing="20.0">
                    <children>
                        <TextField fx:id="txt_search_product" prefHeight="38.0" prefWidth="296.0" promptText="Tìm kiếm"
                                   style="-fx-background-color: white; -fx-border-color: #ced4da; -fx-border-radius: 6px; -fx-background-radius: 6px;"
                                   HBox.hgrow="ALWAYS">
                            <font>
                                <Font size="14.0"/>
                            </font>
                            <padding>
                                <Insets bottom="8.0" left="12.0" right="12.0" top="8.0"/>
                            </padding>
                        </TextField>
                        <Button fx:id="btn_search_product" mnemonicParsing="false"
                                style="-fx-background-color: white; -fx-border-color: #ced4da; -fx-background-radius: 6px; -fx-border-radius: 6px; -fx-text-fill: #495057;"
                                text="Tìm kiếm"
                                onAction="#handleBtnSearchProduct">
                            <font>
                                <Font size="14.0"/>
                            </font>
                            <padding>
                                <Insets bottom="8.0" left="20.0" right="20.0" top="8.0"/>
                            </padding>
                            <cursor>
                                <Cursor fx:constant="HAND"/>
                            </cursor>
                        </Button>
                    </children>
                    <padding>
                        <Insets bottom="5.0" left="20.0" right="20.0" top="5.0"/>
                    </padding>
                </HBox>
                <ScrollPane fitToHeight="true" fitToWidth="true" maxHeight="1.7976931348623157E308"
