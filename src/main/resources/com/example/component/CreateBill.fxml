                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                            </padding>

                            <columnConstraints>
                                <ColumnConstraints halignment="LEFT" minWidth="90.0" prefWidth="100.0"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>

                            <children>
                                <Label styleClass="info-title" text="Họ và Tên:" GridPane.columnIndex="0"
                                       GridPane.rowIndex="0">
                                    <font>
                                        <Font size="14.0"/>
                                    </font>
                                </Label>
                                <Label fx:id="lb_name" textFill="#212529" GridPane.columnIndex="1"
                                       GridPane.rowIndex="0">
                                    <font>
                                        <Font size="15.0"/>
                                    </font>
                                </Label>

                                <Label styleClass="info-title" text="Số điện thoại:" GridPane.columnIndex="0"
                                       GridPane.rowIndex="1">
                                    <font>
                                        <Font size="14.0"/>
                                    </font>
                                </Label>
                                <Label fx:id="lb_phone" textFill="#212529" GridPane.columnIndex="1"
                                       GridPane.rowIndex="1">
                                    <font>
                                        <Font size="15.0"/>
                                    </font>
                                </Label>

                                <Label styleClass="info-title" text="Ngày sinh:" GridPane.columnIndex="0"
                                       GridPane.rowIndex="2">
                                    <font>
                                        <Font size="14.0"/>
                                    </font>
                                </Label>
                                <Label fx:id="lb_dob" textFill="#212529" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                    <font>
                                        <Font size="15.0"/>
                                    </font>
                                </Label>

                                <Label styleClass="info-title" text="Giới tính:" GridPane.columnIndex="0"
                                       GridPane.rowIndex="3">
                                    <font>
                                        <Font size="14.0"/>
                                    </font>
                                </Label>
                                <Label fx:id="lb_gender" textFill="#212529" GridPane.columnIndex="1"
                                       GridPane.rowIndex="3">
                                    <font>
                                        <Font size="15.0"/>
                                    </font>
                                </Label>

                                <Label styleClass="info-title" text="Địa chỉ:" GridPane.columnIndex="0"
                                       GridPane.rowIndex="4">
                                    <font>
                                        <Font size="14.0"/>
                                    </font>
                                </Label>
                                <Label fx:id="lb_address" textFill="#212529" wrapText="true" GridPane.columnIndex="1"
                                       GridPane.rowIndex="4">
                                    <font>
                                        <Font size="15.0"/>
                                    </font>
                                </Label>
                            </children>
                            <rowConstraints>
                                <RowConstraints/>
                                <RowConstraints/>
                                <RowConstraints/>
                                <RowConstraints/>
                                <RowConstraints/>
                            </rowConstraints>
                        </GridPane>
                    </children>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                    </padding>
                </VBox>
                <ScrollPane fitToWidth="true" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
