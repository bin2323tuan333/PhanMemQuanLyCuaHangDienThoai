                            stylesheets="@../../../css/style.css" VBox.vgrow="ALWAYS">
                    <content>
                        <FlowPane fx:id="productlist" alignment="TOP_CENTER" hgap="5.0"
                                  maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                                  prefHeight="226.0" prefWidth="508.0" vgap="5.0">
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                            </padding>
                        </FlowPane>
                    </content>
                </ScrollPane>
            </children>
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </padding>
        </VBox>
        <VBox fx:id="cart_container" maxHeight="1.7976931348623157E308" prefHeight="263.0" prefWidth="217.0"
