<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="249.0"
      prefWidth="500.0" spacing="20.0" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.controllers.ComponentControllers.Form.ChangePassController">
    <children>
        <Label text="Đổi mật khẩu" textFill="#0f172a">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Label>
        <GridPane hgap="10.0" vgap="10.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="235.0" minWidth="10.0" prefWidth="148.0"/>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="339.0" minWidth="10.0" prefWidth="332.0"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            </rowConstraints>
            <children>
                <Label text="Mật khẩu cũ" textFill="#475569">
                    <font>
                        <Font size="13.0"/>
                    </font>
                </Label>
                <Label text="Mật khẩu mới" textFill="#475569" GridPane.rowIndex="1">
                    <font>
                        <Font size="13.0"/>
                    </font>
                </Label>
                <Label text="Nhập lại mật khẩu mới" textFill="#475569" GridPane.rowIndex="2">
                    <font>
                        <Font size="13.0"/>
                    </font>
                </Label>
                <TextField fx:id="txt_oldPass"
                           style="-fx-background-color: #ffffff; -fx-border-color: #cbd5e1; -fx-background-radius: 6; -fx-border-radius: 6;"
                           GridPane.columnIndex="1">
                    <padding>
                        <Insets bottom="6.0" left="8.0" right="8.0" top="6.0"/>
                    </padding>
                </TextField>
                <TextField fx:id="txt_newPass"
                           style="-fx-background-color: #ffffff; -fx-border-color: #cbd5e1; -fx-background-radius: 6; -fx-border-radius: 6;"
                           GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <padding>
                        <Insets bottom="6.0" left="8.0" right="8.0" top="6.0"/>
                    </padding>
                </TextField>
                <TextField fx:id="txt_reNewPass"
                           style="-fx-background-color: #ffffff; -fx-border-color: #cbd5e1; -fx-background-radius: 6; -fx-border-radius: 6;"
                           GridPane.columnIndex="1" GridPane.rowIndex="2">
                    <padding>
                        <Insets bottom="6.0" left="8.0" right="8.0" top="6.0"/>
                    </padding>
                </TextField>
            </children>
        </GridPane>
        <HBox alignment="CENTER" prefHeight="3.0" prefWidth="500.0" spacing="30.0">
            <children>
                <Button mnemonicParsing="false"
                        style="-fx-background-color: #2563eb; -fx-border-radius: 6; -fx-background-radius: 6;"
                        text="Lưu" textFill="WHITE"
                        onAction="#handleBtnSave">
                    <font>
                        <Font name="System Bold" size="14.0"/>
                    </font>

                    <padding>
                        <Insets bottom="6.0" left="20.0" right="20.0" top="6.0"/>
                    </padding>
                </Button>
                <Button mnemonicParsing="false"
                        style="-fx-background-color: #f1f5f9; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #cbd5e1;"
                        text="Hủy"
                        onAction="#handleBtnCancel">
                    <font>
                        <Font size="14.0"/>
                    </font>
                    <padding>
                        <Insets bottom="6.0" left="20.0" right="20.0" top="6.0"/>
                    </padding>
                </Button>
            </children>
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" top="10.0"/>
            </padding>
        </HBox>
    </children>
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
    </padding>
</VBox>
