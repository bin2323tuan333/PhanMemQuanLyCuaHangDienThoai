<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="555.0" prefWidth="1012.0" spacing="20.0" style="-fx-background-color: #f1f5f9;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controllers.ComponentControllers.BillManagementController">

    <children>
      <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #fff; -fx-background-radius: 12;">
         <padding>
            <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
         </padding>
         <children>
            <TextField fx:id="txt_search" promptText="Tìm kiếm sản phẩm" style="-fx-background-color: #f1f5f9; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;" HBox.hgrow="ALWAYS">
               <padding>
                  <Insets bottom="8.0" left="12.0" right="12.0" top="8.0" />
               </padding>
            </TextField>
            <Button fx:id="btn_search_bill" mnemonicParsing="false" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-background-color: #2563eb; -fx-text-fill: white;" text="Tìm kiếm">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor>
               <padding>
                  <Insets bottom="6.0" left="8.0" right="8.0" top="6.0" />
               </padding>
            </Button>
            <Button fx:id="btn_add_bill" mnemonicParsing="false" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #e2e8f0; -fx-text-fill: #475569;" text="Thêm hóa đơn">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor>
               <padding>
                  <Insets bottom="6.0" left="8.0" right="8.0" top="6.0" />
               </padding>
            </Button>
         </children>
      </HBox>

        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <children>
                <Label style="-fx-text-fill: #475569;" text="Trạng thái:" />
                <ComboBox fx:id="cbb_status" prefWidth="150" style="-fx-background-color: white;" />

                <Label style="-fx-text-fill: #475569;" text="Từ ngày:" />
                <DatePicker fx:id="fromDate" prefWidth="150" style="-fx-background-color: white;" />

                <Label style="-fx-text-fill: #475569;" text="Đến ngày:" />
                <DatePicker fx:id="toDate" prefWidth="150" style="-fx-background-color: white;" />
            </children>
        </HBox>

        <VBox prefHeight="480.0" prefWidth="972.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">
            <children>

                <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <FlowPane fx:id="bill_container" hgap="15" pickOnBounds="false" prefHeight="393.0" prefWidth="927.0" prefWrapLength="900" style="-fx-padding: 20;" vgap="15">
                    </FlowPane>
                </ScrollPane>
            </children>
        </VBox>
    </children>

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

</VBox>
