<VBox prefHeight="600" prefWidth="900" spacing="15" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controllers.AdminControllers.CustomerManagementController">
    <padding>

        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #fff; -fx-background-radius: 12;">
        <TextField fx:id="txt_search" promptText="Tìm kiếm sản phẩm" style="-fx-background-color: #f1f5f9; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;" HBox.hgrow="ALWAYS">
            <padding>
                <Insets bottom="8.0" left="12.0" right="12.0" top="8.0" />
            </padding>
        </TextField>
        <Button fx:id="btn_search_customer" mnemonicParsing="false" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-background-color: #2563eb; -fx-text-fill: white;" text="Tìm kiếm">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
            <cursor>
                <Cursor fx:constant="HAND" />
            </cursor>
            <padding>
                <Insets bottom="6.0" left="8.0" right="8.0" top="6.0" />
            </padding>
        </Button>
        <Button fx:id="btn_add_customer" mnemonicParsing="false" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #e2e8f0; -fx-text-fill: #475569;" text="Thêm khách hàng">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
            <cursor>
                <Cursor fx:constant="HAND" />
            </cursor>
            <padding>
                <Insets bottom="6.0" left="8.0" right="8.0" top="6.0" />
            </padding>
        </Button>
        <padding>
            <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
        </padding>
    </HBox>
    <ScrollPane fitToHeight="true" fitToWidth="true" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-border-color: transparent; -fx-border-width: 0;" VBox.vgrow="ALWAYS">
        <content>
            <FlowPane fx:id="customer_container" alignment="TOP_CENTER" hgap="15.0" prefHeight="200.0" prefWidth="200.0" vgap="15.0">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                </padding>
            </FlowPane>
        </content>
    </ScrollPane>

</VBox>
