<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" prefWidth="900" prefHeight="600"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.controllers.AdminControllers.CustomerManagementController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Customer Management"
           style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <HBox spacing="10">
        <TextField fx:id="txtSearch" promptText="Search customer..." HBox.hgrow="ALWAYS"/>
        <Button text="Search" onAction="#handleSearch"/>
        <Button text="Refresh" onAction="#handleRefresh"/>
    </HBox>

    <HBox spacing="10">
        <TextField fx:id="txtName" promptText="Full name"/>
        <TextField fx:id="txtPhone" promptText="Phone"/>
        <TextField fx:id="txtEmail" promptText="Email"/>
        <TextField fx:id="txtAddress" promptText="Address"/>
    </HBox>

    <HBox spacing="10">
        <Button text="Add" onAction="#handleAdd"/>
        <Button text="Update" onAction="#handleUpdate"/>
        <Button text="Delete" onAction="#handleDelete"/>
        <Button text="Clear" onAction="#handleClear"/>
    </HBox>

    <TableView fx:id="customerTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="80"/>
            <TableColumn fx:id="colName" text="Full Name" prefWidth="220"/>
            <TableColumn fx:id="colPhone" text="Phone" prefWidth="160"/>
            <TableColumn fx:id="colEmail" text="Email" prefWidth="220"/>
            <TableColumn fx:id="colAddress" text="Address" prefWidth="300"/>
        </columns>
    </TableView>

</VBox>