<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.controllers.AdminControllers.CustomerManagementController"
      prefWidth="800" prefHeight="600">

    <children>

        <Label text="Customer Management" style="-fx-font-size: 20px; -fx-font-weight: bold;" />

        <!-- Form -->
        <HBox spacing="10">
            <TextField fx:id="txtName" promptText="Name"/>
            <TextField fx:id="txtPhone" promptText="Phone"/>
            <TextField fx:id="txtEmail" promptText="Email"/>
        </HBox>

        <HBox spacing="10">
            <Button text="Add" onAction="#handleAdd"/>
            <Button text="Update" onAction="#handleUpdate"/>
            <Button text="Delete" onAction="#handleDelete"/>
        </HBox>

        <!-- Table -->
        <TableView fx:id="customerTable" prefHeight="400">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="100"/>
                <TableColumn fx:id="colName" text="Name" prefWidth="200"/>
                <TableColumn fx:id="colPhone" text="Phone" prefWidth="150"/>
                <TableColumn fx:id="colEmail" text="Email" prefWidth="200"/>
            </columns>
        </TableView>

    </children>
</VBox>
