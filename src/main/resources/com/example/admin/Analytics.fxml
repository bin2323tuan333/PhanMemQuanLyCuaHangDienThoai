<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.controllers.AdminControllers.AnalyticsController"
            stylesheets="@../../../../../../target/classes/css/admin/analytics.css">

    <top>
        <VBox spacing="8" styleClass="header-area">
            <padding><Insets top="20" left="24" right="24" bottom="8"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="📊" styleClass="logo-icon"/>
                <Label text="Enterprise Shell" styleClass="main-title"/>
                <Label text="GLOBAL OPERATIONS" styleClass="global-subtitle"/>
            </HBox>
            <Label text="Thống kê tổng hợp" styleClass="page-heading"/>
            <Label text="Hiệu suất doanh thu, lợi nhuận và thị phần theo thời gian thực"
                   styleClass="page-sub"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox spacing="24" styleClass="main-content">
                <padding><Insets left="24" right="24" bottom="24" top="12"/></padding>

                <!-- 4 thẻ số liệu -->
                <HBox spacing="15" alignment="CENTER">
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label text="💰 TỔNG DOANH THU" styleClass="stat-title"/>
                        <Label fx:id="totalRevenue" text="1,284,500$" styleClass="stat-value"/>
                        <Label text="▲ +12.5% so với tháng trước" styleClass="stat-trend"/>
                    </VBox>
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label text="📦 TỔNG ĐƠN HÀNG" styleClass="stat-title"/>
                        <Label fx:id="totalOrders" text="42,890" styleClass="stat-value"/>
                        <Label text="▲ +8.2%" styleClass="stat-trend"/>
                    </VBox>
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label text="💵 GIÁ TRỊ ĐƠN HÀNG TB" styleClass="stat-title"/>
                        <Label fx:id="avgOrderValue" text="29.95$" styleClass="stat-value"/>
                        <Label text="▼ -1.2%" styleClass="stat-trend negative"/>
                    </VBox>
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label text="👥 TĂNG TRƯỞNG KH" styleClass="stat-title"/>
                        <Label fx:id="customerGrowth" text="+1,240" styleClass="stat-value"/>
                        <Label text="▲ +15.1%" styleClass="stat-trend"/>
                    </VBox>
                </HBox>

                <!-- Biểu đồ doanh thu & lợi nhuận -->
                <VBox styleClass="chart-card">
                    <Label text="Doanh thu và Lợi nhuận theo tháng" styleClass="card-title"/>
                    <BarChart fx:id="revenueProfitChart" animated="true" prefHeight="300">
                        <xAxis><CategoryAxis label="Tháng"/></xAxis>
                        <yAxis><NumberAxis label="Triệu USD"/></yAxis>
                    </BarChart>
                </VBox>

                <!-- Hàng dưới: Doanh thu theo danh mục + Thị phần -->
                <HBox spacing="20">
                    <VBox styleClass="chart-card" HBox.hgrow="ALWAYS">
                        <Label text="Doanh thu theo danh mục" styleClass="card-title"/>
                        <VBox spacing="12">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="Dịch vụ đám mây" prefWidth="130"/>
                                <ProgressBar progress="0.45" styleClass="cat-progress-cloud"/>
                                <Label text="45%"/>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="Bán phần cứng" prefWidth="130"/>
                                <ProgressBar progress="0.30" styleClass="cat-progress-hardware"/>
                                <Label text="30%"/>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="Tư vấn" prefWidth="130"/>
                                <ProgressBar progress="0.15" styleClass="cat-progress-consult"/>
                                <Label text="15%"/>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="Hợp đồng hỗ trợ" prefWidth="130"/>
                                <ProgressBar progress="0.10" styleClass="cat-progress-support"/>
                                <Label text="10%"/>
                            </HBox>
                        </VBox>
                        <Label text="💡 Dịch vụ đám mây tăng 15% trong quý này" styleClass="insight-text"/>
                    </VBox>

                    <VBox styleClass="chart-card" HBox.hgrow="ALWAYS">
                        <Label text="Thị phần toàn cầu" styleClass="card-title"/>
                        <TableView fx:id="marketShareTable" prefHeight="180">
                            <columns>
                                <TableColumn text="Khu vực" prefWidth="80"/>
                                <TableColumn text="Thị phần" prefWidth="100"/>
                                <TableColumn text="Tăng trưởng" prefWidth="100"/>
                            </columns>
                        </TableView>
                        <Label text="🚀 Cơ hội mở rộng: Thị trường Đông Nam Á tăng 40% YoY.
Khuyến nghị tăng ngân sách marketing tại Singapore và Việt Nam."
                               styleClass="expansion-text" wrapText="true"/>
                    </VBox>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="15" styleClass="footer">
            <padding><Insets right="24" bottom="16" top="8"/></padding>
            <Button text="Xuất báo cáo" styleClass="report-footer-btn"/>
            <Button text="Đăng xuất" styleClass="logout-footer-btn"/>
        </HBox>
    </bottom>
</BorderPane>