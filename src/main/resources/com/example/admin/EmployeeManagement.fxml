<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" prefWidth="900" prefHeight="600"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.controllers.AdminControllers.EmployeeManagementController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Employee Management"
           style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <HBox spacing="10">
        <TextField fx:id="txtSearch" promptText="Search employee..." HBox.hgrow="ALWAYS"/>
        <Button text="Search" onAction="#handleSearch"/>
        <Button text="Refresh" onAction="#handleRefresh"/>
    </HBox>

    <HBox spacing="10">
        <TextField fx:id="txtName" promptText="Full name"/>
        <TextField fx:id="txtPhone" promptText="Phone"/>
        <ComboBox fx:id="cbGender" promptText="Gender"/>
        <TextField fx:id="txtSalary" promptText="Salary"/>
    </HBox>

    <HBox spacing="10">
        <Button text="Add" onAction="#handleAdd"/>
        <Button text="Update" onAction="#handleUpdate"/>
        <Button text="Delete" onAction="#handleDelete"/>
        <Button text="Clear" onAction="#handleClear"/>
    </HBox>

    <TableView fx:id="employeeTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="80"/>
            <TableColumn fx:id="colName" text="Full Name" prefWidth="250"/>
            <TableColumn fx:id="colPhone" text="Phone" prefWidth="180"/>
            <TableColumn fx:id="colGender" text="Gender" prefWidth="120"/>
            <TableColumn fx:id="colSalary" text="Salary" prefWidth="160"/>
        </columns>
    </TableView>

</VBox>