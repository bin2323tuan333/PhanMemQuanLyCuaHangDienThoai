<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" prefWidth="900" prefHeight="600"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.controllers.AdminControllers.ProductManagementController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Product Management"
           style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <HBox spacing="10">
        <TextField fx:id="txtSearch" promptText="Search product..." HBox.hgrow="ALWAYS"/>
        <Button text="Search" onAction="#handleSearch"/>
        <Button text="Refresh" onAction="#handleRefresh"/>
    </HBox>

    <HBox spacing="10">
        <TextField fx:id="txtName" promptText="Product name"/>
        <TextField fx:id="txtBrand" promptText="Brand"/>
        <TextField fx:id="txtPrice" promptText="Price"/>
        <TextField fx:id="txtQuantity" promptText="Quantity"/>
    </HBox>

    <HBox spacing="10">
        <Button text="Add" onAction="#handleAdd"/>
        <Button text="Update" onAction="#handleUpdate"/>
        <Button text="Delete" onAction="#handleDelete"/>
        <Button text="Clear" onAction="#handleClear"/>
    </HBox>

    <TableView fx:id="productTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="80"/>
            <TableColumn fx:id="colName" text="Product Name" prefWidth="250"/>
            <TableColumn fx:id="colBrand" text="Brand" prefWidth="180"/>
            <TableColumn fx:id="colPrice" text="Price" prefWidth="150"/>
            <TableColumn fx:id="colQuantity" text="Quantity" prefWidth="120"/>
        </columns>
    </TableView>

</VBox>