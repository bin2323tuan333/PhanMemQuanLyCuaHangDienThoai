<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane stylesheets="@../../../css/admin/bill.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controllers.AdminControllers.BillManagementController">

    <top>
        <VBox spacing="8" styleClass="header-area">
            <padding><Insets bottom="8" left="24" right="24" top="20" /></padding>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label styleClass="main-title" text="Shop Bán Điện Thoại" />
                <Region HBox.hgrow="ALWAYS" />
                <TextField promptText="Tìm kiếm hóa đơn..." styleClass="search-field" />
            </HBox>
            <Label styleClass="page-heading" text="Quản lý hóa đơn" />
            <Label styleClass="page-sub" text="Theo dõi, duyệt và xuất hóa đơn cho khách hàng" />
        </VBox>
    </top>

    <center>
        <VBox spacing="20" styleClass="main-content">
            <padding><Insets bottom="24" left="24" right="24" top="12" /></padding>

            <!-- Thanh công cụ -->
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Button styleClass="primary-btn" text="➕ Thêm hóa đơn" />
                <Button styleClass="secondary-btn" text="✏️ Sửa" />
                <Button styleClass="danger-btn" text="🗑️ Xóa" />
                <Region HBox.hgrow="ALWAYS" />

                <!-- ComboBox không có items trong FXML, sẽ được gán trong Controller -->
                <ComboBox fx:id="statusCombo" prefWidth="150" promptText="Lọc theo trạng thái" />

                <DatePicker fx:id="fromDate" promptText="Từ ngày" />
                <DatePicker fx:id="toDate" promptText="Đến ngày" />
                <Button styleClass="filter-btn" text="🔍 Lọc" />
            </HBox>

            <!-- Bảng hóa đơn -->
            <TableView fx:id="billTable" styleClass="bill-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn prefWidth="100" text="Mã hóa đơn" />
                    <TableColumn prefWidth="180" text="Khách hàng" />
                    <TableColumn prefWidth="120" text="Ngày tạo" />
                    <TableColumn prefWidth="120" text="Tổng tiền" />
                    <TableColumn prefWidth="120" text="Trạng thái" />
                    <TableColumn prefWidth="100" text="Thao tác" />
                </columns>
                <placeholder>
                    <Label styleClass="placeholder-text" text="Không có hóa đơn nào" />
                </placeholder>
            </TableView>

            <!-- Phân trang -->
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button styleClass="page-btn" text="‹" />
                <Label styleClass="page-info" text="Trang 1 / 5" />
                <Button styleClass="page-btn" text="›" />
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="15" styleClass="footer">
            <padding><Insets bottom="16" right="24" top="8" /></padding>
            <Button styleClass="report-footer-btn" text="Xuất Excel" />
            <Button styleClass="logout-footer-btn" text="Đăng xuất" />
        </HBox>
    </bottom>
</BorderPane>
