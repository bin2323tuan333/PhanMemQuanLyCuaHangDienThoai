<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="1109.0" prefWidth="1097.0" spacing="20.0" style="-fx-background-color: transparent;" stylesheets="@../../../css/admin/dashboard.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controllers.AdminControllers.AdminSettingController">

