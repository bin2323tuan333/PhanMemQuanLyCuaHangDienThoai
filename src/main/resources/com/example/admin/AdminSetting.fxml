<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="1109.0" prefWidth="1097.0" spacing="20.0" style="-fx-background-color: transparent;" stylesheets="@../../../css/admin/dashboard.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controllers.AdminControllers.AdminSettingController">

    <children>
        <!-- Header giống Dashboard -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-padding: 15 20; -fx-border-radius: 10; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, #0000001a, 10, 0, 0, 4);">
            <children>
                <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Shop Bán Điện hoại" />
                <Region HBox.hgrow="ALWAYS" />
                <TextField promptText="Tìm kiếm cài đặt..." style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 6 12;" />
                <Button style="-fx-background-radius: 20; -fx-min-width: 32; -fx-min-height: 32; -fx-background-color: #f1f5f9; -fx-font-weight: bold;" text="?" />
            </children>
        </HBox>

        <!-- Tiêu đề trang -->
        <VBox spacing="5.0">
            <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Cài đặt hệ thống" />
            <Label style="-fx-font-size: 13px; -fx-text-fill: #475569;" text="Quản lý tùy chọn tổ chức, giao thức bảo mật và phân quyền người dùng." />
        </VBox>

        <!-- Nội dung chính: Menu trái + Form phải -->
        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
            <children>
                <!-- Menu bên trái -->
                <VBox prefWidth="220.0" spacing="8.0" style="-fx-background-color: white; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 16 8; -fx-effect: dropshadow(three-pass-box, #0000001a, 10, 0, 0, 4);">
                    <children>
                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #334155; -fx-padding: 0 0 8 12;" text="Cài đặt hệ thống" />
                        <ToggleButton fx:id="generalTab" maxWidth="1.7976931348623157E308" prefHeight="40.0" selected="true" styleClass="menu-button" text="Chung" />
                        <ToggleButton fx:id="securityTab" maxWidth="1.7976931348623157E308" prefHeight="40.0" styleClass="menu-button" text="Bảo mật" />
                        <ToggleButton fx:id="notificationsTab" maxWidth="1.7976931348623157E308" prefHeight="40.0" styleClass="menu-button" text="Thông báo" />
                        <ToggleButton fx:id="usersPermTab" maxWidth="1.7976931348623157E308" prefHeight="40.0" styleClass="menu-button" text="Người dùng &amp; Phân quyền" />
                        <Region VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>

                <!-- Nội dung bên phải -->
                <VBox spacing="20.0" HBox.hgrow="ALWAYS">
                    <children>
                        <!-- Hồ sơ cá nhân -->
                        <VBox spacing="16.0" style="-fx-background-color: white; -fx-border-radius: 10px; -fx-background-radius: 10px; -fx-effect: dropshadow(three-pass-box, #0000001a, 10, 0, 0, 4); -fx-padding: 20;">
                            <children>
                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Hồ sơ cá nhân" />
                                <Label style="-fx-text-fill: #3b82f6; -fx-underline: true; -fx-cursor: hand;" text="Xem hồ sơ công khai" />

                                <GridPane hgap="20" vgap="14">
                                    <columnConstraints>
                                        <ColumnConstraints prefWidth="120" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <Label text="Họ và tên" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                    <TextField fx:id="fullNameField" text="Alexander Curator" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                    <Label text="Email" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                    <TextField fx:id="emailField" text="alex@enterprise-global.com" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                    <Label text="Tiểu sử" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                    <TextArea fx:id="bioArea" prefRowCount="2" text="Trưởng phòng vận hành, giám sát các kênh phân phối số toàn cầu." GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                    <Label text="Ảnh đại diện" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                    <HBox alignment="CENTER_LEFT" spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="3">
                                        <Button style="-fx-background-color: #f1f5f9; -fx-background-radius: 8; -fx-padding: 8 16;" text="Chọn ảnh" />
                                        <Label style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;" text="JPG hoặc PNG, tối đa 2MB" />
                                    </HBox>
                           <rowConstraints>
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                           </rowConstraints>
                                </GridPane>

                                <Separator />
                                <HBox spacing="20">
                                    <Button style="-fx-background-color: #f1f5f9; -fx-background-radius: 8; -fx-padding: 8 16;" text="Cập nhật mật khẩu" />
                                    <Button style="-fx-background-color: #f1f5f9; -fx-background-radius: 8; -fx-padding: 8 16;" text="Xác thực hai yếu tố" />
                                </HBox>
                            </children>
                        </VBox>

                        <!-- Thông tin tổ chức -->
                        <VBox spacing="16.0" style="-fx-background-color: white; -fx-border-radius: 10px; -fx-background-radius: 10px; -fx-effect: dropshadow(three-pass-box, #0000001a, 10, 0, 0, 4); -fx-padding: 20;">
                            <children>
                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Thông tin tổ chức" />
                                <GridPane hgap="20" vgap="14">
                                    <Label text="Tên công ty" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                    <TextField fx:id="companyField" text="Curator Enterprise Solutions" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                    <Label text="Ngành nghề" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                    <TextField fx:id="industryField" text="Công nghệ &amp; SaaS" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                    <Label text="Địa chỉ trụ sở" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                    <TextField fx:id="addressField" text="101 Tech Plaza, Silicon Valley, CA 94025" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                           <columnConstraints>
                              <ColumnConstraints />
                              <ColumnConstraints />
                           </columnConstraints>
                           <rowConstraints>
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                           </rowConstraints>
                                </GridPane>
                            </children>
                        </VBox>

                        <!-- Nút hành động -->
                        <HBox alignment="CENTER_RIGHT" spacing="15">
                            <Button style="-fx-background-color: transparent; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-padding: 8 20;" text="Hủy thay đổi" />
                            <Button style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 20; -fx-font-weight: bold;" text="Lưu cấu hình" />
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- Footer -->
        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <children>
                <Button style="-fx-background-color: transparent; -fx-text-fill: #3b82f6; -fx-border-color: #3b82f6; -fx-border-radius: 6; -fx-padding: 6 16;" text="Tạo báo cáo" />
                <Button style="-fx-background-color: transparent; -fx-text-fill: #ef4444; -fx-border-color: #ef4444; -fx-border-radius: 6; -fx-padding: 6 16;" text="Đăng xuất" />
            </children>
        </HBox>
    </children>

    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
</VBox>
