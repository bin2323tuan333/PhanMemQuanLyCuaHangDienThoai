<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20.0" style="-fx-background-color: #f1f5f9;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controllers.AdminControllers.AdminSettingController">

    <children>

        <!-- Tab menu -->
        <HBox spacing="5.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 5;">
            <children>
                <ToggleButton fx:id="generalTab" style="-fx-background-color: transparent; -fx-padding: 8 20; -fx-background-radius: 6;" text="Thông tin chung" />
                <ToggleButton fx:id="securityTab" style="-fx-background-color: transparent; -fx-padding: 8 20; -fx-background-radius: 6;" text="Bảo mật" />
                <ToggleButton fx:id="usersPermTab" style="-fx-background-color: transparent; -fx-padding: 8 20; -fx-background-radius: 6;" text="Phân quyền" />
            </children>
        </HBox>

        <!-- Tab content - General -->
        <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">
            <children>
                <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Thông tin cá nhân" />

                <GridPane hgap="15" vgap="15">
                    <children>
                        <Label style="-fx-text-fill: #475569;" text="Họ và tên:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="fullNameField" prefWidth="300" style="-fx-background-color: #f1f5f9;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Label style="-fx-text-fill: #475569;" text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <TextField fx:id="emailField" prefWidth="300" style="-fx-background-color: #f1f5f9;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label style="-fx-text-fill: #475569;" text="Số điện thoại:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <TextField fx:id="phoneField" prefWidth="300" style="-fx-background-color: #f1f5f9;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label style="-fx-text-fill: #475569;" text="Địa chỉ:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <TextField fx:id="addressField" prefWidth="300" style="-fx-background-color: #f1f5f9;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <Label style="-fx-text-fill: #475569;" text="Giới thiệu:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                        <TextArea fx:id="bioArea" prefHeight="80" prefWidth="300" style="-fx-background-color: #f1f5f9;" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                    </children>
                    <columnConstraints>
                        <ColumnConstraints prefWidth="100" />
                        <ColumnConstraints prefWidth="300" />
                    </columnConstraints>
               <rowConstraints>
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
               </rowConstraints>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="15">
                    <Button fx:id="btn_save" onAction="#handleSave" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 8 20;" text="Lưu thay đổi" />
                    <Button fx:id="btn_cancel" onAction="#handleCancel" style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 8 20;" text="Hủy bỏ" />
                </HBox>
            </children>
        </VBox>

        <!-- Security tab content (ẩn ban đầu) -->
        <VBox managed="false" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);" visible="false">
            <children>
                <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Đổi mật khẩu" />

                <GridPane hgap="15" vgap="15">
                    <children>
                        <Label style="-fx-text-fill: #475569;" text="Mật khẩu hiện tại:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <PasswordField fx:id="currentPasswordField" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Label style="-fx-text-fill: #475569;" text="Mật khẩu mới:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <PasswordField fx:id="newPasswordField" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label style="-fx-text-fill: #475569;" text="Xác nhận mật khẩu:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <PasswordField fx:id="confirmPasswordField" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    </children>
               <columnConstraints>
                  <ColumnConstraints />
                  <ColumnConstraints />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
               </rowConstraints>
                </GridPane>

                <HBox alignment="CENTER_RIGHT">
                    <Button fx:id="btn_changePassword" onAction="#handleChangePassword" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 8 20;" text="Đổi mật khẩu" />
                </HBox>
            </children>
        </VBox>

        <!-- Label thông báo -->
        <Label fx:id="lb_message" style="-fx-text-fill: #10b981;" />
    </children>

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
