<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20.0" style="-fx-background-color: #f1f5f9;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controllers.AdminControllers.AdminSettingController">

    <children>
        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-padding: 15 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
            <children>
                <Label text="⚙️" style="-fx-font-size: 28px;"/>
                <Label text="Cài đặt hệ thống" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="SYSTEM SETTINGS" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
            </children>
        </HBox>

        <!-- Tab menu -->
        <HBox spacing="5.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 5;">
            <children>
                <ToggleButton fx:id="generalTab" text="Thông tin chung"
                              style="-fx-background-color: transparent; -fx-padding: 8 20; -fx-background-radius: 6;"/>
                <ToggleButton fx:id="securityTab" text="Bảo mật"
                              style="-fx-background-color: transparent; -fx-padding: 8 20; -fx-background-radius: 6;"/>
                <ToggleButton fx:id="notificationsTab" text="Thông báo"
                              style="-fx-background-color: transparent; -fx-padding: 8 20; -fx-background-radius: 6;"/>
                <ToggleButton fx:id="usersPermTab" text="Phân quyền"
                              style="-fx-background-color: transparent; -fx-padding: 8 20; -fx-background-radius: 6;"/>
            </children>
        </HBox>

        <!-- Tab content - General -->
        <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">
            <children>
                <Label text="Thông tin cá nhân" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>

                <GridPane hgap="15" vgap="15">
                    <children>
                        <Label text="Họ và tên:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #475569;"/>
                        <TextField fx:id="fullNameField" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="300" style="-fx-background-color: #f1f5f9;"/>

                        <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #475569;"/>
                        <TextField fx:id="emailField" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="300" style="-fx-background-color: #f1f5f9;"/>

                        <Label text="Số điện thoại:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #475569;"/>
                        <TextField fx:id="phoneField" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="300" style="-fx-background-color: #f1f5f9;"/>

                        <Label text="Địa chỉ:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-text-fill: #475569;"/>
                        <TextField fx:id="addressField" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="300" style="-fx-background-color: #f1f5f9;"/>

                        <Label text="Giới thiệu:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-text-fill: #475569;"/>
                        <TextArea fx:id="bioArea" GridPane.columnIndex="1" GridPane.rowIndex="4" prefHeight="80" prefWidth="300" style="-fx-background-color: #f1f5f9;"/>
                    </children>
                    <columnConstraints>
                        <ColumnConstraints prefWidth="100"/>
                        <ColumnConstraints prefWidth="300"/>
                    </columnConstraints>
                </GridPane>

                <HBox spacing="15" alignment="CENTER_RIGHT">
                    <Button fx:id="btn_save" text="Lưu thay đổi" onAction="#handleSave"
                            style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 8 20;"/>
                    <Button fx:id="btn_cancel" text="Hủy bỏ" onAction="#handleCancel"
                            style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 8 20;"/>
                </HBox>
            </children>
        </VBox>

        <!-- Security tab content (ẩn ban đầu) -->
        <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);" visible="false" managed="false">
            <children>
                <Label text="Đổi mật khẩu" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>

                <GridPane hgap="15" vgap="15">
                    <children>
                        <Label text="Mật khẩu hiện tại:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #475569;"/>
                        <PasswordField fx:id="currentPasswordField" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="300"/>

                        <Label text="Mật khẩu mới:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #475569;"/>
                        <PasswordField fx:id="newPasswordField" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="300"/>

                        <Label text="Xác nhận mật khẩu:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #475569;"/>
                        <PasswordField fx:id="confirmPasswordField" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="300"/>
                    </children>
                </GridPane>

                <HBox alignment="CENTER_RIGHT">
                    <Button fx:id="btn_changePassword" text="Đổi mật khẩu" onAction="#handleChangePassword"
                            style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 8 20;"/>
                </HBox>
            </children>
        </VBox>

        <!-- Label thông báo -->
        <Label fx:id="lb_message" style="-fx-text-fill: #10b981;"/>
    </children>

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>
</VBox>